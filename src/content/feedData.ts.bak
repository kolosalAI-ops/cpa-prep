export type CardType = 'flashcard' | 'quiz' | 'fact' | 'tip';
export type Difficulty = 'dasar' | 'menengah' | 'lanjutan';

export interface FeedCard {
  id: string;
  type: CardType;
  subject: string;
  title: string;
  content: string;
  difficulty?: Difficulty;
  // flashcard
  answer?: string;
  // quiz
  options?: string[];
  correctIndex?: number;
  explanation?: string;
  reasoning?: string;
  // fact
  source?: string;
  whyItMatters?: string;
  // pedagogical extras
  keyTakeaway?: string;
  example?: string;
  mnemonic?: string;
}

